# Koperasi Project Environment Variables
# Copy to .env and fill in actual values

# Google Sheets
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
SERVICE_ACCOUNT_FILE=path/to/service-account.json

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.0

# JWT Authentication
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# Backend (FastAPI)
PORT=8000

# Cloudflare Worker (for wrangler.toml or CI/CD)
# These are typically set via wrangler secret put or GitHub Actions
# GEMINI_API_KEY
# JWT_SECRET
# GOOGLE_CLIENT_EMAIL
# GOOGLE_PRIVATE_KEY
# GOOGLE_SPREADSHEET_ID
